{
  "name": "my-website",
  "version": "1.0.0",
  "description": "Apostrophe Public Demo Site",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node app",
    "dev": "cross-env APOS_DEV=1 nodemon --delay 1000ms -x \"nodemon app.js\"",
    "build": "node app @apostrophecms/asset:build",
    "staging-deploy": "echo \"ℹ️  Clearing module links and installed modules to deploy.\" && rm package-lock.json && rm -r node_modules && npm i && sc-deploy staging",
    "analyze-bundle": "APOS_BUNDLE_ANALYZER=1 node app @apostrophecms/asset:build"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.4.0"
    }
  },
  "dependencies": {
    "@apostrophecms/favicon": "workspace:*",
    "@apostrophecms/import-export": "workspace:*",
    "@apostrophecms/open-graph": "workspace:*",
    "@apostrophecms/seo": "workspace:*",
    "@apostrophecms/vite": "workspace:*",
    "apostrophe": "workspace:*",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "klona": "^2.0.6"
  },
  "author": "Apostrophe Technologies, Inc",
  "license": "MIT",
  "nodemonConfig": {
    "verbose": true,
    "watch": [
      "./app.js",
      "./modules/**/*",
      "./lib/**/*.js",
      "./views/**/*.html",
      "./src/**/*",
      "./node_modules/apostrophe/modules/@apostrophecms/**/*"
    ],
    "ignoreRoot": [
      ".git"
    ],
    "ignore": [
      "./modules/**/ui/*",
      "lib/modules/*/public/js/*.js",
      "locales/*.json",
      "public/uploads",
      "public/apos-frontend",
      "modules/asset/ui/public",
      "data"
    ],
    "ext": "json, js, html, scss, vue"
  },
  "devDependencies": {
    "eslint": "^7.32.0",
    "eslint-config-apostrophe": "^3.4.0",
    "eslint-plugin-node": "^11.1.0",
    "nodemon": "^2.0.12"
  }
}
